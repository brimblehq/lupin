{
  "name": "brimble",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @brimble/web dev",
    "dev:web": "pnpm --filter @brimble/web dev",
    "dev:dashboard": "pnpm --filter @brimble/dashboard dev",
    "build": "pnpm -r build",
    "build:ui": "pnpm --filter @brimble/ui build",
    "build:web": "pnpm --filter @brimble/ui build && pnpm --filter @brimble/web build",
    "build:dashboard": "pnpm --filter @brimble/ui build && pnpm --filter @brimble/dashboard build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.2"
  },
  "packageManager": "pnpm@10.28.2"
}
